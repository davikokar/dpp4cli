<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.1" />
  </startup>
  <appSettings>
    <!--
      Path to the Canon DPP4 installation folder.
      Edit this value if DPP4 is installed in a non-standard location.
    -->
    <add key="dpp4dir" value="C:\Program Files\Canon\Digital Photo Professional 4" />
  </appSettings>
  <runtime>
    <!--
      Allow single objects larger than 2GB on 64-bit.
      Required for TIFF 16-bit buffers from high-resolution RAW files.
    -->
    <gcAllowVeryLargeObjects enabled="true" />
    <!--
      Server GC uses more memory but reduces fragmentation,
      which helps avoid OOM when the native engine allocates
      large contiguous buffers for TIFF 16-bit output.
    -->
    <gcServer enabled="true" />
  </runtime>
</configuration>